    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nfunction canonicalizeUrl(u) {\n  try {\n    const x = new URL(u);\n    x.hash = '';\n    const removeParams = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid','fbclid'];\n    removeParams.forEach(p => x.searchParams.delete(p));\n    return x.toString();\n  } catch {\n    return u || '';\n  }\n}\n\nconst title = ($json.title_raw || '').toLowerCase().replace(/\\s+/g, ' ').trim();\nconst urlCanonica = canonicalizeUrl($json.url_raw || '');\nconst hashTitulo = crypto.createHash('sha1').update(title).digest('hex');\n\nreturn [{ json: { ...$json, url_canonica: urlCanonica, hash_titulo: hashTitulo } }];"
      },
      "id": "Code_Normalize",
      "name": "Code - Normalizar URL e hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        280
      ]
    },
    {
      "parameters": {
        "url": "={{$json.url_canonica}}",
        "options": {
