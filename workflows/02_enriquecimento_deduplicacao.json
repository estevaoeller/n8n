    {
      "parameters": {
        "jsCode": "const title = $json.title_extracted || $json.title_raw || '';\nconst resumo = `Resumo automático: ${title}`.slice(0, 240);\n\nreturn [{\n  json: {\n    ...$json,\n    title_final: title,\n    source: $json.source_raw || '',\n    published_at: $json.published_at || '',\n    tema: $json.tema || 'geral',\n    subtema: $json.subtema || '',\n    resumo_final: resumo,\n    comentario_analitico: '',\n    relevancia: 'media',\n    status: 'revisar'\n  }\n}];"
      },
